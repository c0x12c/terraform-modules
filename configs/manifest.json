{
  "org": "c0x12c",
  "default_branch": "master",
  "features": {
    "dependabot-automerge": {
      "description": "Auto-merge Dependabot PRs for GitHub Actions and Terraform updates",
      "actions": [
        {
          "type": "file_sync",
          "source": "configs/workflows/dependabot-automerge.yml",
          "dest": ".github/workflows/dependabot-automerge.yml",
          "commit_message": "chore: add Dependabot auto-merge workflow"
        }
      ]
    },
    "gh-app-secret": {
      "description": "GH_APP_PRIVATE_KEY secret for Actions and Dependabot",
      "actions": [
        {
          "type": "secret",
          "name": "GH_APP_PRIVATE_KEY",
          "source_file": "set-up-repositories/credentials/github_app_private_key.pem",
          "app": "actions"
        },
        {
          "type": "secret",
          "name": "GH_APP_PRIVATE_KEY",
          "source_file": "set-up-repositories/credentials/github_app_private_key.pem",
          "app": "dependabot"
        }
      ]
    }
  },
  "exclusions": {}
}
